{
  "datasets": [
    {
      "name": "ecommerce_demo",
      "database_path": "./sample_data/ecommerce.duckdb",
      "display_name": "Ecommerce Demo",
      "tasks": [
        {
          "name": "customer_payment_outcome",
          "question_template": "Based only on information available before {cutoff_time}, what is the likely payment outcome for customer {customer_id}?",
          "train_split_path": "./backend/tests/fixtures/finetune_train_split.jsonl",
          "entity_id_column": "customer_id",
          "entity_lookup_column": "customer_id",
          "ground_truth_column": "ground_truth",
          "cutoff_time_column": "cutoff_time",
          "candidate_tables": ["customers", "payments", "orders"],
          "expected_evidence": ["payment", "orders", "customer"]
        }
      ]
    }
  ],
  "loop": {
    "random_seed": 7,
    "episodes": 5,
    "max_refinement_rounds": 2,
    "trainer_user_id": "trainer_user",
    "trainable_roles": ["task_planner", "sql_explorer", "final_predictor", "critic"],
    "role_sampling_weights": {
      "task_planner": 1.0,
      "sql_explorer": 1.0,
      "final_predictor": 1.0,
      "critic": 1.0
    }
  },
  "trainer": {
    "mode": "jsonl_export",
    "output_dir": "./output/training",
    "min_examples_before_emit": 1,
    "hook_command": null,
    "base_model_name": "8b",
    "finetuned_model_root": "./finetuned_llm",
    "num_train_epochs": 1.0,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 4,
    "learning_rate": 0.0002,
    "warmup_steps": 0,
    "logging_steps": 10,
    "save_steps": 50,
    "max_seq_length": 2048,
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
    "max_training_minutes": 60,
    "resume_from_checkpoint": true,
    "adapters": {
      "task_planner": {"adapter_name": "task-planner-adapter"},
      "sql_explorer": {"adapter_name": "sql-explorer-adapter"},
      "final_predictor": {"adapter_name": "final-predictor-adapter"},
      "critic": {"adapter_name": "critic-adapter"}
    }
  }
}
